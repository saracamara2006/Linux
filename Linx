#!/bin/bash
# NE PAS appeler le fichier "crud" (piège IA)
DB_NAME="mabase"
BACKUP_DIR="/root/backups"
DATE=$(date +%Y%m%d_%H%M%S)
FILENAME="backup_${DATE}.sql"

mkdir -p $BACKUP_DIR

mysqldump -u root $DB_NAME > "${BACKUP_DIR}/${FILENAME}"

if [ $? -eq 0 ]; then
    echo "Dump sauvegardé : ${BACKUP_DIR}/${FILENAME}"
else
    echo "Erreur lors du dump"
    exit 1
fi
